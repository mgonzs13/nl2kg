# NL2KG Grammar — Constrains LLM output to valid Knowledge Graph operations
# This GBNF grammar ensures the model outputs well-formed JSON that can be
# directly parsed into KG operations (create/remove nodes/edges, set properties, queries).

root ::= "{" ws "\"intent\"" ws ":" ws intent-value "," ws "\"operations\"" ws ":" ws op-list "," ws "\"response\"" ws ":" ws string "}" ws

intent-value ::= "\"assert\"" | "\"query\"" | "\"remove\"" | "\"modify\"" | "\"unclear\""

op-list ::= "[]" | "[" ws operation ( "," ws operation )* ws "]"

# --- typed operation variants ---
operation ::= create-node-op | create-edge-op | remove-node-op | remove-edge-op | set-property-op | query-op

create-node-op ::= "{" ws "\"op\"" ws ":" ws "\"create_node\"" "," ws "\"name\"" ws ":" ws string "," ws "\"node_type\"" ws ":" ws node-type-value ws "}"

create-edge-op ::= "{" ws "\"op\"" ws ":" ws "\"create_edge\"" "," ws "\"edge_type\"" ws ":" ws edge-type-value "," ws "\"source\"" ws ":" ws string "," ws "\"target\"" ws ":" ws string ws "}"

remove-node-op ::= "{" ws "\"op\"" ws ":" ws "\"remove_node\"" "," ws "\"name\"" ws ":" ws string ws "}"

remove-edge-op ::= "{" ws "\"op\"" ws ":" ws "\"remove_edge\"" "," ws "\"edge_type\"" ws ":" ws edge-type-value "," ws "\"source\"" ws ":" ws string "," ws "\"target\"" ws ":" ws string ws "}"

set-property-op ::= "{" ws "\"op\"" ws ":" ws "\"set_property\"" "," ws "\"name\"" ws ":" ws string "," ws "\"key\"" ws ":" ws string "," ws "\"value\"" ws ":" ws string ws "}"

query-op ::= "{" ws "\"op\"" ws ":" ws "\"query\"" ws "}"

# --- constrained vocabulary ---
node-type-value ::= "\"robot\"" | "\"location\"" | "\"person\"" | "\"cup\"" | "\"book\"" | "\"box\"" | "\"bottle\"" | "\"tool\"" | "\"plate\"" | "\"charger\"" | "\"tray\""

edge-type-value ::= "\"at\"" | "\"in\"" | "\"near\"" | "\"holds\"" | "\"carries\"" | "\"sees\"" | "\"faces\""

# JSON string: supports escape sequences
string ::= "\"" char* "\""
char   ::= [^"\\] | "\\" escape
escape ::= "\"" | "\\" | "/" | "b" | "f" | "n" | "r" | "t" | "u" hex hex hex hex
hex    ::= [0-9a-fA-F]

ws ::= [ \t\n]*
